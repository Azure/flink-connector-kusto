  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "type": "row",
      "title": "Kusto Sink Writer Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Records Sent to Kusto",
      "description": "Total records sent to Kusto sink over time (numRecordsSend + recordsSent)",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "showPoints": "auto" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
          "rawMode": true,
          "resultFormat": "time_series",
          "query": "OTELMetrics\n| where MetricName in ('flink_taskmanager_job_task_operator_numRecordsSend', 'flink_taskmanager_job_task_operator_recordsSent')\n| where $__timeFilter(Timestamp)\n| summarize Value=max(MetricValue) by Timestamp=bin(Timestamp, 15s), MetricName\n| order by Timestamp asc",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Bytes Sent to Blob Storage",
      "description": "Total bytes of CSV data uploaded to blob storage",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "showPoints": "auto" },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
          "rawMode": true,
          "resultFormat": "time_series",
          "query": "OTELMetrics\n| where MetricName in ('flink_taskmanager_job_task_operator_bytesSent', 'flink_taskmanager_job_task_operator_numBytesSend')\n| where $__timeFilter(Timestamp)\n| summarize Value=max(MetricValue) by Timestamp=bin(Timestamp, 15s), MetricName\n| order by Timestamp asc",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Ingestion Successes / Failures",
      "description": "Kusto ingestion outcome counters over time",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "pointSize": 5, "showPoints": "auto" },
          "unit": "short"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Failures" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "Successes" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "Partial" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
          "rawMode": true,
          "resultFormat": "time_series",
          "query": "OTELMetrics\n| where MetricName in ('flink_taskmanager_job_task_operator_succeededIngestions', 'flink_taskmanager_job_task_operator_failedIngestions', 'flink_taskmanager_job_task_operator_partialSucceededIngestions', 'flink_taskmanager_job_task_operator_ingestionSucceeded', 'flink_taskmanager_job_task_operator_ingestionFailed')\n| where $__timeFilter(Timestamp)\n| extend Series = case(\n    MetricName has 'succeeded' or MetricName has 'Success', 'Successes',\n    MetricName has 'failed' or MetricName has 'Failed', 'Failures',\n    'Partial')\n| summarize Value=max(MetricValue) by Timestamp=bin(Timestamp, 15s), Series\n| order by Timestamp asc",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Blobs Uploaded",
      "description": "Number of blobs uploaded to Azure Blob Storage",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "purple" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "showPoints": "auto" },
          "unit": "short"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
          "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
          "rawMode": true,
          "resultFormat": "time_series",
          "query": "OTELMetrics\n| where MetricName == 'flink_taskmanager_job_task_operator_blobsUploaded'\n| where $__timeFilter(Timestamp)\n| summarize Value=max(MetricValue) by Timestamp=bin(Timestamp, 15s)\n| order by Timestamp asc",
          "refId": "A"
        }
      ]
    },
    {
      "type": "row",
      "title": "Latency Metrics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Ingestion Latency (ms)",
      "description": "Ingestion polling latency histogram (p50, p95, p99, mean)",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "pointSize": 5, "showPoints": "auto" },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
          "rawMode": true,
          "resultFormat": "time_series",
          "query": "OTELMetrics\n| where MetricName startswith 'flink_taskmanager_job_task_operator_ingestionLatencyMs'\n| where $__timeFilter(Timestamp)\n| extend Stat = extract('ingestionLatencyMs_(.*)', 1, MetricName)\n| where Stat in ('Mean', 'Median', 'StdDev', 'p95', 'p99')\n| summarize Value=max(MetricValue) by Timestamp=bin(Timestamp, 15s), Stat\n| order by Timestamp asc",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Blob Upload Latency (ms)",
      "description": "Blob upload and serialization latency histogram",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10, "pointSize": 5, "showPoints": "auto" },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
          "rawMode": true,
          "resultFormat": "time_series",
          "query": "OTELMetrics\n| where MetricName startswith 'flink_taskmanager_job_task_operator_blobUploadLatencyMs'\n| where $__timeFilter(Timestamp)\n| extend Stat = extract('blobUploadLatencyMs_(.*)', 1, MetricName)\n| where Stat in ('Mean', 'Median', 'StdDev', 'p95', 'p99')\n| summarize Value=max(MetricValue) by Timestamp=bin(Timestamp, 15s), Stat\n| order by Timestamp asc",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Send Latency (Current Send Time)",
      "description": "Current send time gauge from the Kusto sink writer",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20, "pointSize": 5, "showPoints": "auto" },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        {
