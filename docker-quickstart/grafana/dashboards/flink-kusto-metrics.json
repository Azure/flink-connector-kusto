    {
      "type": "table",
      "title": "Latest Metric Values",
      "description": "Table view of all Kusto sink related metrics with latest values",
      "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 40 },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "MetricName", "desc": false }] },
      "targets": [
        {
          "datasource": { "type": "grafana-azure-data-explorer-datasource", "uid": "adx" },
          "rawMode": true,
          "resultFormat": "table",
          "query": "OTELMetrics\n| where MetricName startswith 'flink_taskmanager_job_task_operator_'\n| where $__timeFilter(Timestamp)\n| summarize LatestValue=arg_max(Timestamp, MetricValue) by MetricName\n| project MetricName, Value=MetricValue, LastUpdated=Timestamp\n| order by MetricName asc",
          "refId": "A"
        }
      ]
