# Environment variables for the Flink Kusto Connector Docker quickstart.
# Copy this file to .env and fill in the values.

# =============================================================================
# Azure Data Explorer (Kusto) Configuration
# =============================================================================

# Kusto cluster URL (engine endpoint)
KUSTO_CLUSTER_URL="https://CLUSTER.REGION.kusto.windows.net"

# Target database name
KUSTO_DATABASE="your-database"

# Target table name - create first using kusto-config/create-table.kql
KUSTO_TABLE="FlinkQuickstart"

# =============================================================================
# Authentication - Azure AD Service Principal
# =============================================================================

# Azure AD Application (client) ID
KUSTO_APP_ID="your-app-id"

# Azure AD Application secret
KUSTO_APP_KEY="your-app-key"

# Azure AD Tenant ID
KUSTO_TENANT_ID="your-tenant-id"

# =============================================================================
# Kafka Configuration
# =============================================================================

# The Kafka topic to produce/consume messages
KAFKA_TOPIC="sensor-readings"
